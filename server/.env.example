PORT=3456

# ═══════════════════════════════════════════════════════════
# MySQL（题目存档，用于次日揭晓答案 + 历史记录）
# 启动时会自动建库建表；完整 DDL 见 server/sql/schema.sql
# ═══════════════════════════════════════════════════════════
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=kaogong_tool
# 可选：mysql2 连接时区，默认 local（与 Node 本机时区一致，如北京时间）
# MYSQL_TIMEZONE=local

# ═══════════════════════════════════════════════════════════
# AI 提供商（按需配置，配了 Key 的才能在页面下拉中选择）
# 复制本文件为 .env 后填写：cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── DeepSeek（推荐，性价比高）──
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── OpenAI（需单独申请，按量付费，非免费）──
# 申请：https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 通义千问（阿里云 DashScope，需单独申请）──
# 申请：https://dashscope.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── 兼容旧版单 Key 写法（等同于 DEEPSEEK_API_KEY）──
# AI_API_KEY=
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-v4-flash
