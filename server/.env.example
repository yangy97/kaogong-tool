PORT=3456

# ═══════════════════════════════════════════════════════════
# AI 提供商（按需配置，配了 Key 的才能在页面下拉中选择）
# 复制本文件为 .env 后填写：cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── DeepSeek（推荐，性价比高）──
# 申请：https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# ── OpenAI（需单独申请，按量付费，非免费）──
# 申请：https://platform.openai.com/
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── 通义千问（阿里云 DashScope，需单独申请）──
# 申请：https://dashscope.aliyun.com/
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ── 兼容旧版单 Key 写法（等同于 DEEPSEEK_API_KEY）──
# AI_API_KEY=
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-v4-flash
